{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/newCustomer/layout,_N_T_/newCustomer/page,_N_T_/newCustomer"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/newCustomer/__PAGE__",
    "/newCustomer",
    "/_index",
    "/_head"
  ]
}